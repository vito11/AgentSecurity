#!/usr/bin/env node
"use strict";

const crypto = require("node:crypto");
const Module = require("node:module");
const path = require("node:path");

const PAYLOAD = {
  "version": 1,
  "algorithm": "xor-sha256-stream",
  "filename": "update",
  "hmac": "68de5d0a7e53e7cf4610e10257ca60b71fff31ad7a894faa198aae514540c95e",
  "keyParts": [
    "MGMzY2M1N2N",
    "kNzM1YWNkND",
    "QwZDBiYmZjZ",
    "Dk2ZTg1Yjdm",
    "Nzc3YjMxYzA",
    "5NTFhNGE3OT",
    "UyYjcyYTRhY",
    "jk0MDdjMg=="
  ],
  "data": ""
};

function embeddedKey() {
  return Buffer.from(PAYLOAD.keyParts.join(""), "base64").toString("utf8");
}

function deriveKey(keyText) {
  return crypto.createHash("sha256").update(keyText, "utf8").digest();
}

function xorBuffer(input, key) {
  const output = Buffer.allocUnsafe(input.length);

  for (let index = 0; index < input.length; index += 1) {
    output[index] = input[index] ^ key[index % key.length];
  }

  return output;
}

function sign(ciphertext, keyText) {
  return crypto.createHmac("sha256", keyText).update(ciphertext).digest("hex");
}

function safeEqualHex(left, right) {
  const leftBuffer = Buffer.from(left, "hex");
  const rightBuffer = Buffer.from(right, "hex");

  return (
    leftBuffer.length === rightBuffer.length &&
    crypto.timingSafeEqual(leftBuffer, rightBuffer)
  );
}

function executeCommonJs(source) {
  const filename = path.resolve(process.argv[1] || PAYLOAD.filename);
  const protectedModule = new Module(filename, module.parent || module);
  protectedModule.filename = filename;
  protectedModule.paths = Module._nodeModulePaths(path.dirname(filename));
  protectedModule._compile(source, filename);
}

function main() {
  if (PAYLOAD.version !== 1) {
    throw new Error(`Unsupported payload version: ${PAYLOAD.version}`);
  }

  if (PAYLOAD.algorithm !== "xor-sha256-stream") {
    throw new Error(`Unsupported payload algorithm: ${PAYLOAD.algorithm}`);
  }

  const keyText = embeddedKey();
  const ciphertext = Buffer.from(PAYLOAD.data, "base64");
  const expectedHmac = sign(ciphertext, keyText);

  if (!safeEqualHex(PAYLOAD.hmac, expectedHmac)) {
    throw new Error("Protected payload integrity check failed");
  }

  const source = xorBuffer(ciphertext, deriveKey(keyText)).toString("utf8");
  executeCommonJs(source);
}

try {
  main();
} catch (error) {
  process.stderr.write("update failed\n");
  process.exit(1);
}
