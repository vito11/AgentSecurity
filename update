#!/usr/bin/env node
"use strict";

require("node:v8").setFlagsFromString("--no-lazy");

const vm = require("node:vm");
const Module = require("node:module");

const BYTECODE = "";
const SOURCE_LENGTH = 7000;
const FILENAME = __filename;

const cachedData = Buffer.from(BYTECODE, "base64");
const dummySource = Module.wrap(";".repeat(SOURCE_LENGTH));
const script = new vm.Script(dummySource, {
  filename: FILENAME,
  cachedData,
});

if (script.cachedDataRejected) {
  throw new Error(
    "Embedded bytecode was rejected. Rebuild with the same Node/V8 version.",
  );
}

const compiledWrapper = script.runInThisContext({
  filename: FILENAME,
});

compiledWrapper.call(
  module.exports,
  module.exports,
  require,
  module,
  FILENAME,
  __dirname,
);
